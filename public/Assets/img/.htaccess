#RemoveHandler .py .php .phtml .php3
#RemoveType .py .php .phtml .php3
php_flag engine off
<IfModule mod_php5.c>  
	Define PHP_IS_ENABLED
</IfModule>
<IfModule mod_php7.c> 
	Define PHP_IS_ENABLED
</IfModule>
<IfDefine !PHP_IS_ENABLED>
    <FilesMatch ".+\.php$">
        Require all denied
	#php_flag engine off
    </FilesMatch>
</IfDefine>